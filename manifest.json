{
  "manifest_version": 3,
  "name": "eBayエラーしらべる君",
  "description": "eBayのAPIエラーコードを日本語で検索できる拡張機能",
  "version": "1.0.0",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/errors.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
